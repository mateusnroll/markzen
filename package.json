{
  "name": "markzen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "esbuild src/platform/electron/main.ts --bundle --platform=node --format=esm --external:electron --outfile=dist-electron/main.mjs && esbuild src/platform/electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload.cjs",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:e2e": "playwright test --project=browser",
    "verify": "npm run typecheck && npm run lint && npm run test:node && npm run test:browser && npm run test:e2e",
    "package": "npm run build && electron-builder --dir",
    "test:shell": "npm run package && playwright test --project=electron",
    "verify:shell": "npm run verify && npm run test:shell"
  },
  "build": {
    "appId": "dev.markzen.app",
    "productName": "Markzen",
    "asar": true,
    "afterPack": "scripts/after-pack.mjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "axe-core": "4.12.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
